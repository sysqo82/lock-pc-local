<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PC Monitor Dashboard</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/leaflet/leaflet.css">
    <script src="/api-config.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/leaflet/leaflet.js"></script>
</head>
<body>
    <div class="dashboard-container">
        <div class="header">
            <h1>PC Activity Monitor</h1>
            <div class="header-nav">
                <% if (userEmail === 'admin@admin.com') { %>
                    <a href="/admin" class="admin-link">Admin Panel</a>
                <% } %>
                <a href="/logout" class="logout-link">Logout</a>
            </div>
        </div>

        <div id="pc-list">
            <!-- PC list will be populated here -->
        </div>

        <div class="block-periods-area">
            <h2>Your Block Periods</h2>

            <div id="block-periods-list">
                <!-- List of block periods will be injected here -->
            </div>

            <div class="block-period-form-wrapper">
                <h3 id="form-title">Add Block Period</h3>
                <form id="block-period-form">
                    <div class="time-inputs">
                        <div>
                            <label for="from-time">From:</label>
                            <input type="time" id="from-time" name="from-time" required>
                        </div>
                        <div>
                            <label for="to-time">To:</label>
                            <input type="time" id="to-time" name="to-time" required>
                        </div>
                    </div>
                    <div class="day-selectors">
                        <label><input type="checkbox" name="day" value="mon"> Mon</label>
                        <label><input type="checkbox" name="day" value="tue"> Tue</label>
                        <label><input type="checkbox" name="day" value="wed"> Wed</label>
                        <label><input type="checkbox" name="day" value="thu"> Thu</label>
                        <label><input type="checkbox" name="day" value="fri"> Fri</label>
                        <label><input type="checkbox" name="day" value="sat"> Sat</label>
                        <label><input type="checkbox" name="day" value="sun"> Sun</label>
                    </div>
                    <div class="form-buttons">
                        <button type="submit" class="btn-save">Save</button>
                        <button type="button" class="btn-cancel">Cancel</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="schedule-visual-area">
            <h2>Your schedule for this week</h2>
            <div id="schedule-visual"></div>
        </div>

        <div class="reminders-area">
            <h2>Your Reminders</h2>

            <div id="reminders-list">
                <!-- List of reminders will be injected here -->
            </div>

            <div class="reminder-form-wrapper">
                <h3 id="reminder-form-title">Add Reminder</h3>
                <form id="reminder-form">
                    <div class="form-group">
                        <label for="reminder-title">Title:</label>
                        <input type="text" id="reminder-title" name="reminder-title" placeholder="e.g., Take a shower" required>
                    </div>
                    <div class="time-inputs">
                        <div>
                            <label for="reminder-time">Time:</label>
                            <input type="time" id="reminder-time" name="reminder-time" required class="reminder-time-input">
                        </div>
                    </div>
                    <div class="day-selectors">
                        <label><input type="checkbox" name="reminder-day" value="mon"> Mon</label>
                        <label><input type="checkbox" name="reminder-day" value="tue"> Tue</label>
                        <label><input type="checkbox" name="reminder-day" value="wed"> Wed</label>
                        <label><input type="checkbox" name="reminder-day" value="thu"> Thu</label>
                        <label><input type="checkbox" name="reminder-day" value="fri"> Fri</label>
                        <label><input type="checkbox" name="reminder-day" value="sat"> Sat</label>
                        <label><input type="checkbox" name="reminder-day" value="sun"> Sun</label>
                    </div>
                    <div class="form-group">
                        <label><input type="checkbox" id="reminder-persistent" name="reminder-persistent"> Persistent (stay on screen until dismissed)</label>
                    </div>
                    <div class="form-buttons">
                        <button type="submit" class="btn-save">Save</button>
                        <button type="button" class="btn-reminder-cancel">Cancel</button>
                    </div>
                </form>
            </div>
        </div>

        <% if (userEmail === 'admin@admin.com') { %>
        <div class="location-area">
            <h2>Device Location</h2>
            <button id="btn-check-location" class="btn-check-location">Check Location</button>
            <p id="location-status" class="location-status"></p>
            <div id="location-map" style="display:none; width:100%; height:400px; margin-top:12px; border-radius:8px; overflow:hidden;"></div>
        </div>
        <% } %>

        <div class="geofence-area">
            <h2>Geofence Zones</h2>
            <p class="geofence-hint">When your device enters a zone it will be prompted to turn on Wi-Fi.</p>
            <div id="geofence-zones-list"></div>
            <div class="geofence-form-wrapper">
                <h3>Add Zone</h3>
                <form id="geofence-form">
                    <div class="geofence-form-fields">
                        <div>
                            <label for="geofence-name">Name</label>
                            <input type="text" id="geofence-name" placeholder="e.g. Home" required maxlength="80">
                        </div>
                        <div>
                            <label for="geofence-radius">Radius (metres)</label>
                            <input type="number" id="geofence-radius" min="50" max="10000" value="150" required>
                        </div>
                    </div>
                    <div class="geofence-location-row">
                        <span id="geofence-coords-display" class="geofence-coords-display">No location selected</span>
                        <button type="button" id="btn-pick-on-map" class="btn-cancel">Pick on map</button>
                        <button type="button" id="btn-use-current-location" class="btn-cancel">My location</button>
                    </div>
                    <input type="hidden" id="geofence-lat">
                    <input type="hidden" id="geofence-lng">
                    <div id="geofence-pick-map"></div>
                    <div class="form-buttons">
                        <button type="submit" class="btn-save">Add Zone</button>
                    </div>
                </form>
            </div>
        </div>

    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/schedule_visual.js"></script>
    <script src="/block_periods.js"></script>
    <script src="/reminders.js"></script>
    <script src="/location.js"></script>
    <script src="/geofence_zones.js"></script>
</body>
</html>
